{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "npm ci --legacy-peer-deps && npm run build"
  },
  "deploy": {
    "startCommand": "npx prisma migrate deploy ; npm start",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindowMs": 60000
  }
}
