// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Contact Form Submission
model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String
  industry  String
  phone     String?
  message   String
  status    String   @default("new") // new, reviewed, responded
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([createdAt])
}

// Demo Request Submission
model DemoRequest {
  id            String   @id @default(cuid())
  name          String
  email         String
  company       String
  industry      String
  jobTitle      String
  phone         String?
  preferredDate DateTime
  timezone      String
  message       String?
  status        String   @default("scheduled") // scheduled, completed, cancelled
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([email])
  @@index([preferredDate])
  @@index([createdAt])
}

// Risk Briefing Submission
model RiskBriefing {
  id            String   @id @default(cuid())
  name          String
  email         String
  company       String
  industry      String
  phone         String?
  preferredDate DateTime
  timezone      String
  message       String?
  status        String   @default("scheduled") // scheduled, completed, cancelled
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([email])
  @@index([preferredDate])
  @@index([createdAt])
}

// Risk Calculator Assessment
model RiskAssessment {
  id              String   @id @default(cuid())
  name            String
  email           String
  company         String
  cobolCodelines  Int
  annualBudget    Int
  hashedPassword  String?
  riskScore       Int?
  generatedReport String?
  status          String   @default("completed")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([email])
  @@index([createdAt])
}

// Free Assessment Form
model FreeAssessment {
  id          String   @id @default(cuid())
  name        String
  email       String
  company     String
  industry    String
  systemType  String
  cobolLines  Int?
  challenges  String?
  status      String   @default("new")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
  @@index([createdAt])
}

// ROI Calculator Data
model ROICalculation {
  id               String   @id @default(cuid())
  email            String?
  company          String?
  currentCost      Int
  migrationMethod  String
  timelineMonths   Int
  estimatedSavings Int
  roiPercentage    Float
  breakEvenMonths  Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([email])
  @@index([createdAt])
}
