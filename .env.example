# =============================================================================
# Yumesorai Website - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Sanity CMS
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=
# Read token for previews (optional)
SANITY_PREVIEW_TOKEN=

# -----------------------------------------------------------------------------
# Analytics (Plausible)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=yumesorai.com
NEXT_PUBLIC_PLAUSIBLE_API_HOST=https://plausible.io

# -----------------------------------------------------------------------------
# HubSpot CRM
# -----------------------------------------------------------------------------
HUBSPOT_API_KEY=
HUBSPOT_PORTAL_ID=

# -----------------------------------------------------------------------------
# Email Service (choose one)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
# SENDGRID_API_KEY=

# -----------------------------------------------------------------------------
# Bot Protection (Cloudflare Turnstile)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET=

# -----------------------------------------------------------------------------
# Sentry Error Tracking
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# -----------------------------------------------------------------------------
# Site Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://yumesorai.com
NEXT_PUBLIC_SITE_NAME=Yumesorai

# -----------------------------------------------------------------------------
# Database (if applicable)
# -----------------------------------------------------------------------------
# DATABASE_URL=

# -----------------------------------------------------------------------------
# Vercel-specific (auto-populated on Vercel)
# -----------------------------------------------------------------------------
# VERCEL_URL=
# VERCEL_ENV=
